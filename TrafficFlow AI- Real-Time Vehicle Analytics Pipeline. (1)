{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"gpuType":"T4","mount_file_id":"1O_nEIS6yhFkA73UrnMHM-KRnGkQq-x5M","authorship_tag":"ABX9TyPZB2FbHyH/YpIxz5zsHKKh"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"},"accelerator":"GPU"},"cells":[{"cell_type":"markdown","source":["**Cell 1: Setup & The Smart Fallback Downloader**"],"metadata":{"id":"CBvH5tYiQSDl"}},{"cell_type":"code","source":["# 1. Install Dependencies\n","!pip install ultralytics supervision opencv-python-headless -q\n","\n","import os\n","from google.colab import files\n","import ultralytics\n","\n","video_filename = \"highway.mp4\"\n","video_url = \"https://raw.githubusercontent.com/roboflow-ai/notebooks/main/assets/traffic-video.mp4\"\n","\n","# Clean up old broken files\n","if os.path.exists(video_filename):\n","    os.remove(video_filename)\n","\n","print(\"Attempting to download video from server...\")\n","!wget -q {video_url} -O {video_filename}\n","\n","# 2. Validation Check\n","download_successful = False\n","if os.path.exists(video_filename):\n","    size_mb = os.path.getsize(video_filename) / (1024 * 1024)\n","    if size_mb > 1.0:\n","        print(f\"✅ SUCCESS! Video downloaded automatically. Size: {size_mb:.2f} MB\")\n","        download_successful = True\n","\n","# 3. The Fallback Mechanism (Trigger Manual Upload)\n","if not download_successful:\n","    print(f\"❌ Server blocked the download (File size: {size_mb:.5f} MB).\")\n","    print(\"⚠️ TRIGGERING FALLBACK: Please upload a traffic video (MP4) from your computer below.\")\n","\n","uploadedhis pops up the Google Colab file upload button!\n","    upluploadedoaded = files.upload()\n","\n","    if len(uploaded) > 0:\n","        # Get the name of the file you just uploaded\n","        uploaded_name = list(uploaded.keys())[0]\n","\n","        # Rename it to highway.mp4 so the rest of the code doesn't break\n","        os.rename(uploaded_name, video_filename)\n","        print(f\"✅ SUCCESS! Your file '{uploaded_name}' was uploaded and renamed to '{video_filename}'.\")\n","    else:\n","        print(\"❌ You cancelled the upload. Please run this cell again.\")"],"metadata":{"id":"681jTDgrQW0E"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":[],"metadata":{"id":"5s5FCB_gQRoO"}},{"cell_type":"markdown","source":["**Cell 2: The Core AI Engine (AdvancedVehicleTracker)\n","This is the updated, bug-free class using the correct BoxAnnotator syntax.**"],"metadata":{"id":"T2ARmEcJQlbm"}},{"cell_type":"code","source":["import cv2\n","import numpy as np\n","import supervision as sv\n","from ultralytics import YOLO\n","import time\n","\n","class AdvancedVehicleTracker:\n","    def __init__(self, model_path=\"yolo11n.pt\"):\n","        print(\"Loading YOLO model...\")\n","        self.model = YOLO(model_path)\n","        self.tracker = \"bytetrack.yaml\"\n","\n","        # Define Counting Line (You can adjust the Y-coordinate '500' depending on your video)\n","        self.line_start = sv.Point(0, 500)\n","        self.line_end = sv.Point(1280, 500)\n","        self.line_zone = sv.LineZone(start=self.line_start, end=self.line_end)\n","\n","        # Setup Annotators\n","        self.box_annotator = sv.BoxAnnotator(thickness=2, color_lookup=sv.ColorLookup.TRACK)\n","        self.label_annotator = sv.LabelAnnotator(text_scale=0.5, color_lookup=sv.ColorLookup.TRACK)\n","        self.trace_annotator = sv.TraceAnnotator(thickness=2, trace_length=50, color_lookup=sv.ColorLookup.TRACK)\n","        self.line_annotator = sv.LineZoneAnnotator(thickness=3, text_thickness=2, text_scale=1.5)\n","\n","        # Classes: 2=car, 3=motorcycle, 5=bus, 7=truck\n","        self.target_classes = [2, 3, 5, 7]\n","\n","    def draw_hud(self, frame, fps):\n","        overlay = frame.copy()\n","        cv2.rectangle(overlay, (20, 20), (450, 180), (0, 0, 0), -1)\n","        cv2.addWeighted(overlay, 0.6, frame, 0.4, 0, frame)\n","\n","        cv2.putText(frame, \"AI TRAFFIC ANALYTICS\", (40, 60), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 255, 255), 2)\n","        cv2.putText(frame, f\"Vehicles Moving Down: {self.line_zone.in_count}\", (40, 110), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 0), 2)\n","        cv2.putText(frame, f\"Vehicles Moving Up:   {self.line_zone.out_count}\", (40, 150), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 0, 255), 2)\n","        cv2.putText(frame, f\"FPS: {fps:.1f}\", (frame.shape[1] - 150, 50), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 255, 0), 2)\n","        return frame\n","\n","    def process_video(self, source_path, output_path):\n","        cap = cv2.VideoCapture(source_path)\n","        width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n","        height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n","        video_fps = int(cap.get(cv2.CAP_PROP_FPS))\n","        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n","\n","        fourcc = cv2.VideoWriter_fourcc(*'mp4v')\n","        out = cv2.VideoWriter(output_path, fourcc, video_fps, (width, height))\n","\n","        print(f\"Processing Video: {width}x{height} @ {video_fps} FPS\")\n","        frame_count = 0\n","\n","        while cap.isOpened():\n","            ret, frame = cap.read()\n","            if not ret:\n","                break\n","\n","            start_time = time.time()\n","            frame_count += 1\n","\n","            if frame_count % 50 == 0:\n","                print(f\"Processing frame {frame_count}/{total_frames}\")\n","\n","            results = self.model.track(\n","                source=frame, persist=True, tracker=self.tracker,\n","                conf=0.3, iou=0.5, verbose=False\n","            )[0]\n","\n","            detections = sv.Detections.from_ultralytics(results)\n","            mask = np.isin(detections.class_id, self.target_classes)\n","            detections = detections[mask]\n","\n","            if detections.tracker_id is not None:\n","                self.line_zone.trigger(detections)\n","                frame = self.trace_annotator.annotate(scene=frame, detections=detections)\n","                frame = self.box_annotator.annotate(scene=frame, detections=detections)\n","                frame = self.label_annotator.annotate(scene=frame, detections=detections)\n","\n","            frame = self.line_annotator.annotate(frame=frame, line_counter=self.line_zone)\n","            processing_fps = 1.0 / (time.time() - start_time)\n","            frame = self.draw_hud(frame, processing_fps)\n","            out.write(frame)\n","\n","        cap.release()\n","        out.release()\n","        print(f\"✅ Video processing complete! Saved to {output_path}\")"],"metadata":{"id":"OnYX20ikQjT5"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["**Cell 3: Execute Tracking**"],"metadata":{"id":"bF_h5AgzRXb4"}},{"cell_type":"code","source":["input_video = \"/content/highway.mp4\"\n","output_video = \"advanced_tracking_output.mp4\"\n","\n","# Make sure the video exists before starting\n","if os.path.exists(input_video):\n","    tracker = AdvancedVehicleTracker(model_path=\"yolo11n.pt\")\n","    tracker.process_video(input_video, output_video)\n","else:\n","    print(\"❌ Cannot run. 'highway.mp4' is missing. Please run Cell 1 first.\")"],"metadata":{"id":"bJpjS1A1KkJV"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["**Cell 4: View and Download Video**"],"metadata":{"id":"EamquHK3RlC-"}},{"cell_type":"code","source":["from IPython.display import HTML, display\n","from base64 import b64encode\n","\n","compressed_path = \"compressed_output.mp4\"\n","\n","if not os.path.exists(output_video) or os.path.getsize(output_video) == 0:\n","    print(f\"❌ ERROR: Cannot find or output video is 0 bytes. Check Cell 3.\")\n","else:\n","    print(\"Compressing video for web viewing...\")\n","    # Using crf 23 for better visual quality for your portfolio\n","    !ffmpeg -y -v error -i {output_video} -vcodec libx264 -crf 23 {compressed_path}\n","\n","    if os.path.exists(compressed_path):\n","        print(\"✅ Compression complete!\")\n","\n","        mp4 = open(compressed_path,'rb').read()\n","        data_url = \"data:video/mp4;base64,\" + b64encode(mp4).decode()\n","        display(HTML(f\"\"\"\n","        <video width=800 controls>\n","              <source src=\"{data_url}\" type=\"video/mp4\">\n","        </video>\n","        \"\"\"))\n","\n","        files.download(compressed_path)\n","    else:\n","        print(\"❌ ERROR: FFmpeg failed.\")"],"metadata":{"id":"fK-FoEeEKmpa"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["**Finished The Code**"],"metadata":{"id":"9ZRcyBWxRv_e"}}]}